# Auto detect text files and perform LF normalization
* text=auto
# LFS track large files
*.tif filter=lfs diff=lfs merge=lfs -text
*.tiff filter=lfs diff=lfs merge=lfs -text
*.zip filter=lfs diff=lfs merge=lfs -text
*.geojson filter=lfs diff=lfs merge=lfs -text
data/GeoJson/*.json filter=lfs diff=lfs merge=lfs -text
data/Potree/**/*.json filter=lfs diff=lfs merge=lfs -text
data/Potree/**/*.bin filter=lfs diff=lfs merge=lfs -text
